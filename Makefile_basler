# Makefile for Basler Pylon version
# Modified to use Basler Pylon API instead of Pleora SDK

# Basler Pylon paths (adjust if your installation is different)
PYLON_ROOT ?= /opt/pylon

# Compiler and linker flags for Pylon
CFLAGS=-D_UNIX_ -D_LINUX_ -Iinclude -Iinclude/LabJack -Iinclude/john -I. \
       -I/usr/include/opencv4 \
       $(shell $(PYLON_ROOT)/bin/pylon-config --cflags) \
       -std=c++11

LDFLAGS=-L/opt/lib_tomo/labjack \
        -lpthread -lm \
        -lopencv_core -lopencv_imgcodecs -lopencv_highgui -lopencv_imgproc \
        -ltiff -lboost_system -lboost_filesystem -lboost_chrono -lboost_thread \
        $(shell $(PYLON_ROOT)/bin/pylon-config --libs) \
        -lLjack -llabjackusb -llabjackusbcpp -lmsleep

OBJDIR = obj/Release
CC = g++

# Target for Basler version
tomo_basler : main_basler.o fonctions.o scan_functions.o
	$(CC) -o bin/Release/tomo_basler $(OBJDIR)/main_basler.o $(OBJDIR)/fonctions.o \
	      $(OBJDIR)/scan_functions.o $(LDFLAGS)

# Target for original Pleora version
tomo_manip : main.o fonctions.o scan_functions.o
	$(CC) -o bin/Release/tomo_manip $(OBJDIR)/main.o $(OBJDIR)/fonctions.o \
	      $(OBJDIR)/scan_functions.o -O3 $(LDFLAGS)

fonctions.o : src/fonctions.cpp
	$(CC) -c $< $(CFLAGS) -o $(OBJDIR)/$@

scan_functions.o : src/scan_functions.cpp
	$(CC) -c $< $(CFLAGS) -o $(OBJDIR)/$@

main.o : main.cpp
	$(CC) -c $< $(CFLAGS) -o $(OBJDIR)/$@

main_basler.o : main_basler.cpp
	$(CC) -c $< $(CFLAGS) -o $(OBJDIR)/$@

clean :
	rm -f obj/Release/*.o obj/Release/src/*.o bin/Release/tomo_manip bin/Release/tomo_basler

mrproper: clean
	rm -f bin/Release/tomo_manip bin/Release/tomo_basler

.PHONY: clean mrproper
